# Copiá este archivo a .env.local y completá los valores.
# En Vercel: Settings → Environment Variables (mismas claves).

# ── Admin (/admin/login) ──────────────────────────────────────────────────────
ADMIN_USERNAME=macizo
ADMIN_PASSWORD=cambiar_por_una_contraseña_segura

# ── Sesiones (cookies de admin y acceso a presentaciones) ───────────────────
# Generar: openssl rand -base64 32
SESSION_SECRET=cambiar_por_secreto_de_al_menos_16_caracteres

# ── Vercel Blob (Storage → Blob → Read-Write token) ───────────────────────────
# Obligatorio para publicar presentaciones y exigir código de acceso en /p/[slug]
BLOB_READ_WRITE_TOKEN=

# ── Código fijo para transformacion-digital (6 caracteres A-Z / 2-9) ─────────
# Usado por: npm run publish -- transformacion-digital
TRANSFORMACION_DIGITAL_ACCESS_CODE=LABGRP
